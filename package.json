{
  "name": "wish-directory",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css,scss,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "build:analyze": "vite build && npx vite-bundle-visualizer"
  },
  "dependencies": {
    "@vueuse/core": "^11.3.0",
    "axios": "^1.10.0",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "js-cookie": "^3.0.5",
    "pinia": "^3.0.3",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1",
    "web-vitals": "^4.2.4",
    "workbox-window": "^7.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^22.16.3",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "@vite-pwa/assets-generator": "^0.2.6",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "^9.33.0",
    "happy-dom": "^16.8.1",
    "prettier": "^3.6.2",
    "rollup-plugin-visualizer": "^5.14.0",
    "sass": "^1.89.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^0.21.2",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.2.12"
  }
}
